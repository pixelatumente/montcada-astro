---
import BaseLayout from "../layouts/BaseLayout.astro";
import Schema from "../components/Schema.astro";
import AdUnit from "../components/AdUnit.astro";
import data from "../data/enriched-negocios.json";

const categories = data.categories.filter(c => c.slug !== "mir");
const total = data.total || categories.reduce((s, c) => s + c.count, 0);
const topCategories = categories.sort((a, b) => b.count - a.count);
const enrichedCount = data.negocios.filter(n => n.enriched?.google_place_id).length;

// Get top rated businesses
const topRated = data.negocios
  .filter(n => n.enriched?.google_rating && n.enriched?.google_rating >= 4.5)
  .sort((a, b) => (b.enriched?.google_reviews || 0) - (a.enriched?.google_reviews || 0))
  .slice(0, 6);

const categoryIcons = {
  "Restaurantes": { icon: "🍽️", bg: "#FDF0ED" },
  "Talleres": { icon: "🔧", bg: "#E8F5F0" },
  "Fisioterapeutas": { icon: "💪", bg: "#EDE9FE" },
  "Peluquerías": { icon: "💇", bg: "#FCE7F3" },
  "Concesionarios": { icon: "🚗", bg: "#DBEAFE" },
  "Veterinarios": { icon: "🐾", bg: "#F0FDF4" },
  "Abogados": { icon: "⚖️", bg: "#FEF3C7" },
  "Dentistas": { icon: "🦷", bg: "#F0F9FF" },
  "Servicios públicos y trámites": { icon: "🏛️", bg: "#F1F5F9" },
};
---

<BaseLayout
  title="Negocios en Montcada i Reixac | Montcada Online"
  description={`Directorio de comercios, negocios y profesionales de Montcada i Reixac. Encuentra restaurantes, talleres, peluquerías, veterinarios y más. ${total} negocios locales.`}
>
  <Schema type="WebPage" data={{ name: "Montcada Online", description: `Guía de negocios de Montcada i Reixac con ${total} comercios` }} />

  <!-- Hero Section -->
  <section class="hero-section" style="position:relative;min-height:560px;display:flex;align-items:center;overflow:hidden">
    <!-- Background image -->
    <img src="/montcada-hero.jpg" alt="Montcada i Reixac" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0" />
    
    <!-- Gradient overlay (warm) -->
    <div style="position:absolute;inset:0;background:linear-gradient(135deg, rgba(232,93,74,0.85) 0%, rgba(28,25,23,0.75) 100%);z-index:1"></div>
    
    <div style="position:relative;z-index:2;width:100%">
      <div class="container hero-content" style="text-align:center;padding:100px 0">
        <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);padding:8px 18px;border-radius:100px;margin-bottom:24px;font-size:0.85rem;color:rgba(255,255,255,0.9);font-weight:500">
          <span>📍</span> Directorio Local — Montcada i Reixac
        </div>
        
        <h1 style="font-family:var(--font-serif);font-size:3.6rem;font-weight:700;margin-bottom:16px;line-height:1.1;color:white">
          Tu guía de<br/>
          <span style="background:linear-gradient(135deg, #FCD34D, #F59E0B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">negocios locales</span>
        </h1>
        <p style="font-size:1.2rem;max-width:560px;margin:0 auto 20px;color:rgba(255,255,255,0.85);line-height:1.6;font-weight:300">
          Descubre comercios, servicios y profesionales cerca de ti. Datos verificados, opiniones reales.
        </p>

        <!-- Stats row -->
        <div class="stats-row" style="display:flex;justify-content:center;gap:48px;flex-wrap:wrap;margin-top:36px">
          <div style="text-align:center">
            <div class="stat-number" style="font-size:2.5rem;font-weight:700;color:#FCD34D;line-height:1">{total}</div>
            <div style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.7);margin-top:4px">Negocios</div>
          </div>
          <div class="hero-stat-divider" style="width:1px;background:rgba(255,255,255,0.2);align-self:stretch"></div>
          <div style="text-align:center">
            <div class="stat-number" style="font-size:2.5rem;font-weight:700;color:#FCD34D;line-height:1">{categories.length}</div>
            <div style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.7);margin-top:4px">Categorías</div>
          </div>
          <div class="hero-stat-divider" style="width:1px;background:rgba(255,255,255,0.2);align-self:stretch"></div>
          <div style="text-align:center">
            <div class="stat-number" style="font-size:2.5rem;font-weight:700;color:#FCD34D;line-height:1">{enrichedCount}</div>
            <div style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.7);margin-top:4px">Verificados</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Grid -->
  <section class="container" style="padding:60px 24px;margin-top:-30px;position:relative;z-index:3">
    <div class="categories-card" style="background:var(--card);border-radius:var(--radius-lg);padding:48px;box-shadow:var(--shadow-lg)">
      <div style="text-align:center;margin-bottom:40px">
        <h2 style="font-family:var(--font-serif);font-size:2rem;font-weight:700;color:var(--text);margin-bottom:8px">
          Explora por categoría
        </h2>
        <p style="color:var(--text-light);font-size:1rem">
          {total} negocios organizados en {categories.length} categorías
        </p>
      </div>

      <div class="categories-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px">
        {topCategories.map(cat => {
          const style = categoryIcons[cat.name] || { icon: "📍", bg: "#F5F0EB" };
          const slug = cat.slug || cat.name.toLowerCase().replace(/[\s|]+/g, "-").replace(/[íí]/g, "i").replace(/[ó]/g, "o").replace(/[ú]/g, "u");
          return (
            <a href={`/${slug}/`} style="display:flex;align-items:center;gap:16px;padding:20px 22px;border-radius:var(--radius);background:var(--card);border:1px solid var(--border);transition:all 0.25s ease;text-decoration:none;color:var(--text);box-shadow:var(--shadow-sm)"
              onmouseover="this.style.borderColor='var(--primary)';this.style.boxShadow='0 4px 14px rgba(232,93,74,0.15)';this.style.transform='translateY(-2px)'"
              onmouseout="this.style.borderColor='var(--border)';this.style.boxShadow='var(--shadow-sm)';this.style.transform='translateY(0)'">
              <span style="font-size:1.8rem;width:48px;height:48px;display:flex;align-items:center;justify-content:center;background:{style.bg};border-radius:12px;flex-shrink:0">{style.icon}</span>
              <div>
                <h3 style="font-size:1rem;font-weight:600;margin-bottom:2px">{cat.name}</h3>
                <p style="color:var(--text-light);font-size:0.8rem">{cat.count} {cat.count === 1 ? "negocio" : "negocios"}</p>
              </div>
              <span style="margin-left:auto;color:var(--text-muted);font-size:1.1rem">→</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Negocio Destacado -->
  <section style="padding:20px 0 20px">
    <div class="container">
      <a href="/peluquerias/peluqueria-gaby/" style="display:block;text-decoration:none;color:var(--text);background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-md);transition:all 0.3s ease"
        onmouseover="this.style.boxShadow='0 12px 40px rgba(232,93,74,0.18)';this.style.transform='translateY(-4px)';this.style.borderColor='var(--primary)'"
        onmouseout="this.style.boxShadow='var(--shadow-md)';this.style.transform='translateY(0)';this.style.borderColor='var(--border)'">
        <div class="featured-grid" style="display:grid;grid-template-columns:1fr 1fr;min-height:320px">
          <!-- Left: Content -->
          <div class="featured-content" style="padding:40px 36px;display:flex;flex-direction:column;justify-content:center">
            <div style="display:inline-flex;align-items:center;gap:6px;background:var(--primary-light);color:var(--primary-dark);padding:6px 14px;border-radius:100px;font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:16px;width:fit-content">
              ⭐ Negocio Destacado
            </div>
            <h2 style="font-family:var(--font-serif);font-size:2rem;font-weight:700;margin-bottom:8px;line-height:1.15">Peluquería Gaby</h2>
            <p style="color:var(--text-light);font-size:0.95rem;line-height:1.6;margin-bottom:16px;max-width:380px">
              Realza tu belleza con estilo propio. Expertos en coloración, trenzas africanas y estética personalizada.
            </p>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap">
              <span style="color:var(--accent);font-size:1.1rem;letter-spacing:2px">★★★★½</span>
              <span style="font-weight:700;font-size:1rem">4.5</span>
              <span style="color:var(--text-muted);font-size:0.85rem">(23 reseñas)</span>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
              <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;background:var(--secondary-light);color:var(--secondary);border-radius:100px;font-size:0.8rem;font-weight:500">● Abierto ahora</span>
              <span style="color:var(--text-light);font-size:0.85rem">📍 Rambla dels Països Catalans, 75</span>
            </div>
            <div style="margin-top:20px;display:flex;gap:10px;flex-wrap:wrap">
              <span style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:var(--primary);color:white;border-radius:100px;font-size:0.85rem;font-weight:600">📞 695 52 68 62</span>
              <span style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:var(--bg-alt);color:var(--text);border-radius:100px;font-size:0.85rem;font-weight:500;border:1px solid var(--border)">✂️ 6 servicios</span>
            </div>
          </div>
          <!-- Right: Services Preview -->
          <div class="featured-services" style="background:linear-gradient(135deg, var(--primary) 0%, #C94D3A 100%);padding:40px 32px;display:flex;flex-direction:column;justify-content:center;gap:14px;position:relative;overflow:hidden">
            <div style="position:absolute;inset:0;background:url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")"></div>
            {["✂️ Corte y Estilo", "🎨 Coloración Experta", "👑 Trenzas Africanas", "💅 Manicura y Pedicura", "🏠 Servicio a Domicilio", "💬 Trato Personalizado"].map(s => (
              <div style="position:relative;z-index:1;display:flex;align-items:center;gap:10px;padding:12px 16px;background:rgba(255,255,255,0.12);backdrop-filter:blur(4px);border-radius:10px;color:white;font-size:0.9rem;font-weight:500">
                {s}
              </div>
            ))}
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══ AdSense: Anuncio entre destacado y más valorados ═══ -->
  <section class="container" style="padding:8px 24px">
    <AdUnit format="horizontal" />
  </section>

  <!-- Top Rated Businesses -->
  {topRated.length > 0 && (
    <section style="padding:20px 0 60px">
      <div class="container">
        <div class="top-rated-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:28px;flex-wrap:wrap;gap:8px">
          <div>
            <h2 style="font-family:var(--font-serif);font-size:1.8rem;font-weight:700;color:var(--text);margin-bottom:4px">
              ⭐ Más valorados
            </h2>
            <p style="color:var(--text-light);font-size:0.95rem">
              Los negocios mejor puntuados por los vecinos de Montcada
            </p>
          </div>
        </div>

        <div class="top-rated-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px">
          {topRated.map(n => {
            const ne = n.enriched || {};
            const fullStars = Math.floor(ne.google_rating || 0);
            const hasHalf = (ne.google_rating || 0) - fullStars >= 0.3;
            const stars = "★".repeat(fullStars) + (hasHalf ? "½" : "") + "☆".repeat(5 - fullStars - (hasHalf ? 1 : 0));
            const catSlug = n.category.toLowerCase().replace(/[\s|]+/g, "-").replace(/[íí]/g, "i").replace(/[ó]/g, "o").replace(/[ú]/g, "u");
            const catIcon = categoryIcons[n.category]?.icon || "📍";
            return (
              <a href={`/${catSlug}/${n.slug}/`} style="display:block;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;text-decoration:none;color:var(--text);transition:all 0.3s ease;box-shadow:var(--shadow-sm)"
                onmouseover="this.style.boxShadow='var(--shadow-lg)';this.style.transform='translateY(-4px)'"
                onmouseout="this.style.boxShadow='var(--shadow-sm)';this.style.transform='translateY(0)'">
                <div style="padding:24px 24px 20px">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px">
                    <div>
                      <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:3px">{n.title}</h3>
                      <span style="display:inline-flex;align-items:center;gap:4px;font-size:0.75rem;color:var(--text-light);background:var(--bg-alt);padding:3px 10px;border-radius:100px">
                        {catIcon} {n.category}
                      </span>
                    </div>
                    {ne.google_price_level && (
                      <span style="font-size:0.75rem;color:var(--text-muted);padding:2px 8px;background:var(--bg-alt);border-radius:4px">
                        {ne.google_price_level === "PRICE_LEVEL_INEXPENSIVE" ? "€" :
                         ne.google_price_level === "PRICE_LEVEL_MODERATE" ? "€€" : "€€€"}
                      </span>
                    )}
                  </div>
                  
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                    <span style="color:#F59E0B;font-size:1.1rem;letter-spacing:1px">{stars}</span>
                    <span style="font-weight:600;font-size:1rem;color:var(--text)">{ne.google_rating}</span>
                    <span style="color:var(--text-muted);font-size:0.85rem">({ne.google_reviews} reseñas)</span>
                  </div>

                  {ne.google_address && (
                    <p style="color:var(--text-light);font-size:0.85rem;margin-top:4px">📍 {ne.google_address.split(",").slice(0,2).join(",")}</p>
                  )}
                  
                  <div style="display:flex;align-items:center;gap:12px;margin-top:12px;flex-wrap:wrap">
                    {n.phone && <span style="font-size:0.85rem;color:var(--text-light)">📞 {n.phone}</span>}
                    {ne.google_website && (
                      <span style="font-size:0.85rem;color:var(--primary);font-weight:500">🌐 Web</span>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ AdSense: Anuncio antes de CTA ═══ -->
  <section class="container" style="padding:8px 24px">
    <AdUnit format="horizontal" />
  </section>

  <!-- CTA Section -->
  <section style="background:var(--bg-alt);padding:72px 0">
    <div class="container" style="text-align:center">
      <div style="max-width:640px;margin:0 auto">
        <div style="font-size:3rem;margin-bottom:16px">🏪</div>
        <h2 style="font-family:var(--font-serif);font-size:2rem;font-weight:700;margin-bottom:12px;color:var(--text)">
          ¿Tienes un negocio en Montcada?
        </h2>
        <p style="color:var(--text-light);font-size:1.05rem;line-height:1.7;margin-bottom:8px">
          Si tu comercio o servicio no aparece en nuestro directorio, puedes solicitarnos que lo añadamos. Todos los datos se verifican con Google Places para ofrecer información actualizada.
        </p>
        <div class="cta-badges" style="margin-top:32px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
          <span class="cta-badge" style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-size:0.9rem;color:var(--text-light)">
            📍 Montcada i Reixac
          </span>
          <span style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-size:0.9rem;color:var(--text-light)">
            🏘️ Vallès Occidental
          </span>
          <span style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-size:0.9rem;color:var(--text-light)">
            📊 {total} negocios verificados
          </span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
