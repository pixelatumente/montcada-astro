---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";
import data from "../../data/enriched-negocios.json";

export async function getStaticPaths() {
  const paths = [];
  for (const n of data.negocios) {
    const catSlug = n.category.toLowerCase().replace(/[\s|]+/g, "-").replace(/[íí]/g, "i").replace(/[ó]/g, "o").replace(/[ú]/g, "u");
    paths.push({
      params: { categoria: catSlug, slug: n.slug },
      props: { negocio: n, catSlug }
    });
  }
  return paths;
}

const { negocio, catSlug } = Astro.props;
const e = negocio.enriched || {};

// Build description
const ratingText = e.google_rating ? `${e.google_rating} estrellas (${e.google_reviews} reseñas en Google)` : "";
const desc = `${negocio.title} en Montcada i Reixac. ${e.google_address || ""}. ${ratingText}. ${negocio.phone ? "Teléfono: " + negocio.phone : ""}`.trim();

const title = `${negocio.title} | Montcada i Reixac`;
const canon = `https://montcada.com.es/${catSlug}/${negocio.slug}/`;

// Format hours
function formatHours(hours) {
  if (!hours || !hours.length) return null;
  const dayMap = { "lunes": "Lun", "martes": "Mar", "miércoles": "Mié", "jueves": "Jue", "viernes": "Vie", "sábado": "Sáb", "domingo": "Dom" };
  return hours.map(h => {
    for (const [es, en] of Object.entries(dayMap)) {
      if (h.toLowerCase().startsWith(es)) return h.replace(es, en);
    }
    return h;
  });
}
const days = formatHours(e.google_hours);

// Rating stars
function stars(rating) {
  if (!rating) return "";
  const full = Math.floor(rating);
  const half = rating - full >= 0.3;
  let s = "★".repeat(full);
  if (half) s += "½";
  s += "☆".repeat(5 - full - (half ? 1 : 0));
  return s;
}

const hasEnriched = e.google_place_id ? true : false;
const cleanContent = negocio.clean_content || negocio.excerpt || "";
const subTitulo = (negocio.category === "Restaurantes" ? "Restaurante" :
                   negocio.category === "Talleres" ? "Taller" :
                   negocio.category === "Fisioterapeutas" ? "Fisioterapeuta" :
                   negocio.category === "Peluquerías" ? "Peluquería" :
                   negocio.category === "Concesionarios" ? "Concesionario" :
                   negocio.category === "Veterinarios" ? "Veterinario" :
                   negocio.category === "Abogados" ? "Abogado" :
                   negocio.category === "Dentistas" ? "Dentista" :
                   negocio.category === "mir" ? "Servicio público" :
                   negocio.category === "Servicios públicos y trámites" ? "Servicio público" :
                   negocio.category).toLowerCase();
---

<BaseLayout title={title} description={desc.slice(0, 160)} canonical={canon}>
  <Schema type="LocalBusiness" data={{
    name: negocio.title,
    description: desc.slice(0, 200),
    url: canon,
    telephone: e.google_phone || negocio.phone || undefined,
    address: e.google_address || true,
    aggregateRating: e.google_rating ? {
      ratingValue: e.google_rating,
      reviewCount: e.google_reviews,
      bestRating: 5
    } : undefined
  }} />
  <Schema type="BreadcrumbList" data={{
    items: [
      { name: "Inicio", url: "https://montcada.com.es/" },
      { name: negocio.category, url: `https://montcada.com.es/${catSlug}/` },
      { name: negocio.title, url: canon }
    ]
  }} />

  <!-- Breadcrumb -->
  <div style="background:var(--bg-alt);padding:16px 0;border-bottom:1px solid var(--border)">
    <div class="container">
      <nav style="font-size:0.85rem;color:var(--text-light)">
        <a href="/" style="color:var(--text-light)">Inicio</a>
        <span style="margin:0 8px">/</span>
        <a href={`/${catSlug}/`} style="color:var(--text-light)">{negocio.category}</a>
        <span style="margin:0 8px">/</span>
        <span style="color:var(--text);font-weight:500">{negocio.title}</span>
      </nav>
    </div>
  </div>

  <article style="max-width:900px;margin:0 auto;padding:32px 24px 60px">
    
    <!-- Main Card -->
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-md)">
      
      <!-- Header Section -->
      <div style="padding:36px 36px 24px;border-bottom:1px solid var(--border)">
        <p style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--primary);font-weight:600;margin-bottom:6px">{subTitulo} en Montcada i Reixac</p>
        <h1 style="font-family:var(--font-serif);font-size:2.4rem;font-weight:700;margin-bottom:12px;line-height:1.15">{negocio.title}</h1>
        
        {hasEnriched && e.google_rating && (
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;flex-wrap:wrap">
            <div style="display:flex;align-items:center;gap:4px">
              <span style="color:#F59E0B;font-size:1.4rem;letter-spacing:2px">{stars(e.google_rating)}</span>
              <span style="font-weight:700;font-size:1.2rem;color:var(--text)">{e.google_rating}</span>
            </div>
            <span style="color:var(--text-muted);font-size:0.9rem">({e.google_reviews} reseñas en Google)</span>
          </div>
        )}
        
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:8px">
          <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;background:var(--primary-light);color:var(--primary-dark);border-radius:100px;font-size:0.8rem;font-weight:500">{negocio.category}</span>
          {e.google_business_status === "OPERATIONAL" && (
            <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;background:var(--secondary-light);color:var(--secondary);border-radius:100px;font-size:0.8rem;font-weight:500">● Abierto ahora</span>
          )}
          {e.google_business_status === "CLOSED_TEMPORARILY" && (
            <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;background:#FEF3C7;color:#92400E;border-radius:100px;font-size:0.8rem;font-weight:500">⚠ Cerrado temporalmente</span>
          )}
        </div>
      </div>

      <!-- Info Grid -->
      <div class="slug-grid" style="padding:28px 36px;display:grid;grid-template-columns:1fr 1fr;gap:24px">
        {(e.google_phone || negocio.phone) && (
          <div style="padding:16px;background:var(--bg);border-radius:var(--radius);border:1px solid var(--border)">
            <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:4px">📞 Teléfono</div>
            <a href={`tel:${(e.google_phone || negocio.phone).replace(/\s/g, "")}`} style="font-size:1.1rem;font-weight:600;color:var(--primary)">
              {e.google_phone || negocio.phone}
            </a>
          </div>
        )}
        {e.google_address && (
          <div style="padding:16px;background:var(--bg);border-radius:var(--radius);border:1px solid var(--border)">
            <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:4px">📍 Dirección</div>
            <div style="font-size:0.95rem;color:var(--text)">{e.google_address}</div>
          </div>
        )}
        {e.google_website && (
          <div style="padding:16px;background:var(--bg);border-radius:var(--radius);border:1px solid var(--border)">
            <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:4px">🌐 Web</div>
            <a href={e.google_website} target="_blank" rel="noopener" style="font-size:0.9rem;color:var(--primary);font-weight:500;word-break:break-all">
              {e.google_website.replace(/^https?:\/\//, "").split("/")[0]}
            </a>
          </div>
        )}
        {e.google_price_level && (
          <div style="padding:16px;background:var(--bg);border-radius:var(--radius);border:1px solid var(--border)">
            <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:4px">💰 Precio</div>
            <div style="font-size:0.95rem;font-weight:500">
              {e.google_price_level === "PRICE_LEVEL_INEXPENSIVE" ? "Económico 💚" :
               e.google_price_level === "PRICE_LEVEL_MODERATE" ? "Moderado 💛" :
               e.google_price_level === "PRICE_LEVEL_EXPENSIVE" ? "Caro ❤️" :
               e.google_price_level === "PRICE_LEVEL_VERY_EXPENSIVE" ? "Muy caro 💎" : e.google_price_level}
            </div>
          </div>
        )}
      </div>

      <!-- Hours Section -->
      {days && days.length > 0 && (
        <div style="padding:0 36px 24px">
          <div style="border-top:1px solid var(--border);padding-top:24px">
            <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:12px">🕐 Horario</div>
            <div class="slug-hours-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:4px 40px;font-size:0.9rem">
              {days.map(d => {
                const parts = d.split(": ");
                return (
                  <div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px dashed var(--border)">
                    <span style="font-weight:500">{parts[0]}</span>
                    <span style="color:var(--text-light)">{parts.slice(1).join(": ") || "—"}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      <!-- Action Buttons -->
      <div style="padding:0 36px 24px;display:flex;flex-direction:column;gap:10px">
        {(e.google_phone || negocio.phone) && (
          <a href={`https://wa.me/34${(e.google_phone || negocio.phone).replace(/[\s\+\(\)\-]/g, "")}`} target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:14px 24px;background:linear-gradient(135deg, #25D366, #128C7E);color:white;border-radius:var(--radius);font-weight:600;font-size:1rem;text-decoration:none;transition:all 0.2s"
            onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 14px rgba(37,211,102,0.4)'"
            onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar WhatsApp
            <span style="font-size:0.8rem;opacity:0.7">↗</span>
          </a>
        )}
        {e.google_maps_url && (
          <a href={e.google_maps_url} target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:14px 24px;background:linear-gradient(135deg, #1a73e8, #1557B0);color:white;border-radius:var(--radius);font-weight:600;font-size:1rem;text-decoration:none;transition:all 0.2s"
            onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 14px rgba(26,115,232,0.4)'"
            onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'">
            <span>📍</span> Ver en Google Maps
            <span style="font-size:0.8rem;opacity:0.7">↗</span>
          </a>
        )}
      </div>

      <!-- SEO Description -->
      {cleanContent && (
        <div style="padding:24px 36px 32px;border-top:1px solid var(--border);background:var(--bg)">
          <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:12px">📋 Información</div>
          <div style="font-size:0.95rem;color:var(--text);line-height:1.9">
            {cleanContent.split("\n").filter(l => l.trim()).map(line => (
              <p style="margin-bottom:10px">{line}</p>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- More Businesses Section -->
    <section style="margin-top:48px">
      <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:600;margin-bottom:20px;color:var(--text)">
        Más {negocio.category.toLowerCase()} en Montcada i Reixac
      </h2>
      <div class="more-businesses-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px">
        {data.negocios.filter(n => n.category === negocio.category && n.slug !== negocio.slug).slice(0, 6).map(n => {
          const ne = n.enriched || {};
          const nr = ne.google_rating;
          const s = nr ? "★".repeat(Math.floor(nr)) + "☆".repeat(5 - Math.floor(nr)) : "";
          const nCatSlug = n.category.toLowerCase().replace(/[\s|]+/g, "-").replace(/[íí]/g, "i").replace(/[ó]/g, "o").replace(/[ú]/g, "u");
          return (
            <a href={`/${nCatSlug}/${n.slug}/`} style="display:block;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-decoration:none;color:var(--text);transition:all 0.2s;box-shadow:var(--shadow-sm)"
              onmouseover="this.style.boxShadow='var(--shadow-md)';this.style.transform='translateY(-3px)'"
              onmouseout="this.style.boxShadow='var(--shadow-sm)';this.style.transform='translateY(0)'">
              <strong style="font-size:1rem;font-weight:600">{n.title}</strong>
              {s && (
                <div style="margin-top:4px;display:flex;align-items:center;gap:4px">
                  <span style="color:#F59E0B;font-size:0.9rem;letter-spacing:1px">{s}</span>
                  <span style="color:var(--text-light);font-size:0.8rem">{nr}</span>
                </div>
              )}
              {n.phone && <p style="color:var(--text-light);font-size:0.8rem;margin-top:4px">📞 {n.phone}</p>}
            </a>
          );
        })}
      </div>
    </section>
  </article>
</BaseLayout>
